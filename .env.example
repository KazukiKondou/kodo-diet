# アプリ設定サンプル。実値は .env に置く（.env はコミットしない）。
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kodo_diet?schema=public"
# openssl rand -base64 32 で生成
AUTH_SECRET="CHANGE_ME"
AUTH_URL="http://localhost:3015"
AUTH_TRUST_HOST=true
EMAIL_FROM="Cocoa <no-reply@example.com>"
# 未設定ならマジックリンクをサーバログ/画面に表示（無料）。
# 本番で実メール送信する場合のみ SMTP を設定（例: Resend 無料枠）:
# EMAIL_SERVER="smtp://resend:YOUR_RESEND_API_KEY@smtp.resend.com:465"
NEXT_PUBLIC_APP_NAME="Cocoa"
